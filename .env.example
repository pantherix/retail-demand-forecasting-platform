# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/retailgpt
USE_SQLITE=true

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_DO_NOT_USE_DEFAULT
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM Providers (at least one required for Copilot) ─────────────────────────
LLM_PROVIDER=openai
# Options: openai | groq | ollama

OPENAI_API_KEY=your-openai-key-here
GROQ_API_KEY=your-groq-key-here
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Optional Integrations ─────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# SENTRY_DSN=your-sentry-dsn-here

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SEED_DATA=0
WORKER_INTERVAL_SECONDS=30
NEXT_PUBLIC_ENABLE_RANDOM_TELEMETRY=true

